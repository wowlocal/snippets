#! /bin/bash

set -e

cd "$(dirname "$0")"

# Find Sparkle's generate_appcast in SPM build artifacts
SPARKLE_BIN=$(find ~/Library/Developer/Xcode/DerivedData -path "*/SourcePackages/artifacts/sparkle/Sparkle/bin" -type d 2>/dev/null | head -n 1)

if [ -z "$SPARKLE_BIN" ]; then
    echo "Error: Could not find Sparkle binary tools."
    echo "Build the project in Xcode first to download the Sparkle package."
    exit 1
fi

GENERATE_APPCAST="$SPARKLE_BIN/generate_appcast"
DMGs_DIR="created-dmgs"
MAXIMUM_DELTAS="${MAXIMUM_DELTAS:-3}"

echo "Using generate_appcast from: $SPARKLE_BIN"
echo "DMGs directory: $DMGs_DIR"
echo "Maximum deltas: $MAXIMUM_DELTAS"

if ! [[ "$MAXIMUM_DELTAS" =~ ^[0-9]+$ ]]; then
    echo "Error: MAXIMUM_DELTAS must be a non-negative integer."
    exit 1
fi

$GENERATE_APPCAST --maximum-deltas "$MAXIMUM_DELTAS" "$DMGs_DIR"

echo "Appcast generated at $DMGs_DIR/appcast.xml"
